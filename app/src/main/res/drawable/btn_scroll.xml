<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#262A3A"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/btn_scroll"/>
            <stroke android:width="1dp" android:color="@color/touchpad_border"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
